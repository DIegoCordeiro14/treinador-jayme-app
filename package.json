{
  "name": "treinador-jayme-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:nutrition": "tsc src/lib/edn/nutrition-autopilot.ts src/lib/edn/nutrition-intelligence.ts --outDir scripts/.tmp --module commonjs --target es2019 --skipLibCheck && node scripts/test-nutrition-engine.js && node scripts/test-nutrition-intelligence.js",
    "test:cardio": "tsc src/lib/cardio/endurance-engine.ts --outDir scripts/.tmp --module commonjs --target es2019 --skipLibCheck && node scripts/test-endurance-engine.js",
    "test:athlete": "tsc src/lib/edn/athlete-intelligence-engine.ts --outDir scripts/.tmp --module commonjs --target es2019 --skipLibCheck && node scripts/test-athlete-intelligence.js",
    "test:v81": "tsc src/lib/edn/progress-intelligence-engine.ts src/lib/edn/training-periodization-engine.ts src/lib/edn/workout-intelligence-engine.ts --outDir scripts/.tmp --module commonjs --target es2019 --skipLibCheck && node scripts/test-v81-engines.js"
  },
  "dependencies": {
    "next": "14.2.0",
    "react": "^18",
    "react-dom": "^18",
    "@supabase/supabase-js": "^2.43.0",
    "@supabase/ssr": "^0.3.0",
    "@anthropic-ai/sdk": "^0.27.0",
    "openai": "^4.57.0",
    "@google/generative-ai": "^0.17.0",
    "recharts": "^2.12.0",
    "date-fns": "^3.6.0",
    "react-hook-form": "^7.51.0",
    "zod": "^3.22.0",
    "@hookform/resolvers": "^3.3.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0",
    "lucide-react": "^0.378.0",
    "class-variance-authority": "^0.7.0",
    "@tanstack/react-query": "^5.40.0",
    "@tanstack/react-query-devtools": "^5.40.0",
    "zustand": "^4.5.0",
    "immer": "^10.1.1",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-checkbox": "^1.0.4",
    "framer-motion": "^11.0.0",
    "next-themes": "^0.3.0",
    "sonner": "^1.4.0",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/leaflet": "^1.9.14",
    "postcss": "^8",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.1.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "commonjs"
          }
        }
      ]
    }
  }
}
